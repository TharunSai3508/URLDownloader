<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 4-stop vivid diagonal gradient: hot-pink → violet → electric-blue → cyan -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:color="#FFFF006E" android:offset="0.00" />
                <item android:color="#FF9500FF" android:offset="0.33" />
                <item android:color="#FF3D5AFE" android:offset="0.66" />
                <item android:color="#FF00E5FF" android:offset="1.00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-right starburst highlight -->
    <path
        android:fillColor="#22FFFFFF"
        android:pathData="M108,0 L108,64 Q68,56 44,0 Z" />

    <!-- Bottom-left diffuse highlight -->
    <path
        android:fillColor="#16FFFFFF"
        android:pathData="M0,108 L64,108 Q74,64 0,40 Z" />

    <!-- Centre soft radial glow (makes icon feel lit from inside) -->
    <path android:pathData="M54,54 m-46,0 a46,46 0 1,0 92,0 a46,46 0 1,0 -92,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="46"
                android:type="radial">
                <item android:color="#28FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle top-left sparkle dot -->
    <path
        android:fillColor="#30FFFFFF"
        android:pathData="M22,18 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0" />
    <!-- Subtle bottom-right sparkle dot -->
    <path
        android:fillColor="#25FFFFFF"
        android:pathData="M86,90 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />

</vector>
