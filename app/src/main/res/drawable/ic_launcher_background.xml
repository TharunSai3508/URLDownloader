<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Main diagonal gradient: deep purple → electric blue → cyan -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:color="#FF7C4DFF" android:offset="0.0" />
                <item android:color="#FF3D5AFE" android:offset="0.45" />
                <item android:color="#FF00BCD4" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-right highlight arc -->
    <path
        android:fillColor="#18FFFFFF"
        android:pathData="M108,0 L108,70 Q60,60 40,0 Z" />

    <!-- Bottom-left ambient glow -->
    <path
        android:fillColor="#12FFFFFF"
        android:pathData="M0,108 L68,108 Q78,60 0,38 Z" />

    <!-- Soft center radial glow -->
    <path android:pathData="M54,54 m-50,0 a50,50 0 1,0 100,0 a50,50 0 1,0 -100,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="50"
                android:type="radial">
                <item android:color="#20FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
