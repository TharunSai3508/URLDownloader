        android:fillColor="#FFFFFFFF"
        android:pathData="M46,12 L62,12 L62,44 L78,44 L54,68 L30,44 L46,44 Z" />

    <!-- 2 · Receiver tray (U-shape: left side + base + right side) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M18,62 L28,62 L28,76 L80,76 L80,62 L90,62 L90,84 L18,84 Z" />

    <!-- 3 · URL chain link hint — two small semi-transparent pills -->
    <path
        android:fillColor="#BFFFFFFF"
        android:pathData="M22,90 A4,4 0 0 1 26,86 L44,86 A4,4 0 0 1 48,90 A4,4 0 0 1 44,94 L26,94 A4,4 0 0 1 22,90 Z" />
    <path
